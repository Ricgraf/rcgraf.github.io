import React, { useState } from 'react';
import { motion } from 'framer-motion';
import { ShoppingCart, User, LogOut, Package, Users, BarChart3, Search, Menu } from 'lucide-react';
import { Card, CardContent } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';

export default function RicgrafSystemPrototype() {
  const [active, setActive] = useState('produtos');
  const [cart, setCart] = useState(0);

  const produtos = [
    { id: 1, nome: 'Cartão de Visita Premium', preco: 'R$ 49,90' },
    { id: 2, nome: 'Banner 1x1m', preco: 'R$ 79,90' },
    { id: 3, nome: 'Adesivo Personalizado', preco: 'R$ 29,90' },
    { id: 4, nome: 'Panfleto Couchê', preco: 'R$ 39,90' },
  ];

  return (
    <div className="flex h-screen bg-slate-100">
      <aside className="w-72 bg-gradient-to-b from-blue-900 via-fuchsia-700 to-yellow-400 text-white p-5">
        <div className="text-2xl font-bold mb-8">RICGRAF</div>
        <div className="space-y-3">
          {[
            ['produtos', Package, 'Produtos'],
            ['usuarios', Users, 'Usuários'],
            ['estatisticas', BarChart3, 'Estatísticas'],
            ['carrinho', ShoppingCart, 'Carrinho'],
          ].map(([key, Icon, label]) => (
            <button key={key} onClick={() => setActive(key)} className="w-full flex items-center gap-3 p-3 rounded-2xl hover:bg-white/20">
              <Icon size={18} /> {label}
            </button>
          ))}
        </div>
      </aside>

      <main className="flex-1">
        <header className="bg-white shadow p-4 flex justify-between items-center">
          <div className="flex items-center gap-3">
            <Menu />
            <span className="font-semibold text-lg">Sistema de Vendas Ricgraf</span>
          </div>
          <div className="flex items-center gap-3">
            <User />
            <Button>Login</Button>
            <Button variant="outline">Logout</Button>
          </div>
        </header>

        <section className="p-6">
          {active === 'produtos' && (
            <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }}>
              <div className="flex gap-3 mb-5">
                <Input placeholder="Pesquisar produtos gráficos..." />
                <Button><Search size={16} /></Button>
              </div>
              <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
                {produtos.map((p) => (
                  <Card key={p.id} className="rounded-2xl shadow-lg">
                    <CardContent className="p-5 space-y-3">
                      <h2 className="font-bold text-lg">{p.nome}</h2>
                      <p className="text-slate-600">{p.preco}</p>
                      <div className="flex gap-2">
                        <Button onClick={() => setCart(cart + 1)}>Adicionar ao Carrinho</Button>
                        <Button variant="outline">Comprar</Button>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            </motion.div>
          )}

          {active === 'usuarios' && <div className="text-xl font-semibold">Gestão de Usuários (ADM)</div>}
          {active === 'estatisticas' && <div className="text-xl font-semibold">Dashboard de Vendas</div>}
          {active === 'carrinho' && <div className="text-xl font-semibold">Carrinho com {cart} itens</div>}
        </section>
      </main>
    </div>
  );
}
